        "amount_usdc": "1000000",
        "timestamp": 1620000000,
        "deal_id": "",
        "listing_id": "",
        "metadata": {}
      },
      "expected_canonical_payload_v1": "v1|tx_type=stake|amount_usdc=1000000|token=<TOKEN>|user=<USER>|timestamp=1620000000|deal_id=|listing_id=|meta=",
