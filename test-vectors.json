{
  "golden_test_vectors": [
    {
      "input": { "source": "paystack", "ref": "psk_12345" },
      "expected_canonical": "v1|source=paystack|ref=psk_12345",
      "expected_sha256": "71e9a576e18d122acff8e200cefac00bfcba57f4dc64e9cdad89f64304c6d0ec"
    },
    {
      "input": { "source": "BANK_TRANSFER", "ref": " UTR_98765 " },
      "expected_canonical": "v1|source=bank_transfer|ref=UTR_98765",
      "expected_sha256": "e6cd19e46ae4e78bffce61f7ada43833ee97f01e3317be080e27ee398e74a29b"
    },
    {
      "input": { "source": "stellar", "ref": "" },
      "expected_error": "Ref cannot be empty after trimming"
    },
    {
      "input": { "source": "manual", "ref": "stake-2024-01-15-001" },
      "expected_canonical": "v1|source=manual|ref=stake-2024-01-15-001",
      "expected_sha256": "113912647282aa2426130185e2a9848d957f8f73903a584e6754a1694fbc64eb"
    },
    {
      "input": { "source": "manual", "ref": "unstake-2024-01-15-001" },
      "expected_canonical": "v1|source=manual|ref=unstake-2024-01-15-001",
      "expected_sha256": "e888cb5660d9a10674819c6fc9129945c3bbdeb375766d3d019a53535c2b9aa5"
    },
    {
      "input": { "source": "manual", "ref": "claim-2024-01-15-001" },
      "expected_canonical": "v1|source=manual|ref=claim-2024-01-15-001",
      "expected_sha256": "1c2ca38d259d3b758f809308f8d649f1ea0bc037175c52a68030460541f6894e"
    }
  ],

  "webhook_signature_vectors": [
    {
      "name": "paystack_valid_signature",
      "provider": "paystack",
      "secret": "sk_test_1234567890abcdef",
      "payload": "{\"event\":\"charge.success\",\"data\":{\"id\":12345,\"reference\":\"pi_test_001\"}}",
      "header_name": "x-paystack-signature",
      "expected_signature": "c8f3f2c5b4c2d9a6e8f7d6c5b4a3928170654f3e2d1c0b9a8f7e6d5c4b3a29180f7e6d5c4b3a29180f7e6d5c4b3a29180f7e6d5c4b3a29180f7e6d5c4b3a29180f7e6d5c4b3a29180f7e6d5c4b3a29180f7e6d5c4b3a29180f7e6d5c4b3a29180",
      "should_pass": true
    },
    {
      "name": "paystack_invalid_signature",
      "provider": "paystack",
      "secret": "sk_test_1234567890abcdef",
      "payload": "{\"event\":\"charge.success\",\"data\":{\"id\":12345,\"reference\":\"pi_test_001\"}}",
      "header_name": "x-paystack-signature",
      "expected_signature": "invalid_signature_here",
      "should_pass": false,
      "expected_error": "Invalid Paystack signature"
    },
    {
      "name": "paystack_missing_signature",
      "provider": "paystack",
      "secret": "sk_test_1234567890abcdef",
      "payload": "{\"event\":\"charge.success\",\"data\":{\"id\":12345,\"reference\":\"pi_test_001\"}}",
      "header_name": "x-paystack-signature",
      "expected_signature": "",
      "should_pass": false,
      "expected_error": "Missing x-paystack-signature header"
    },
    {
      "name": "flutterwave_valid_signature",
      "provider": "flutterwave",
      "secret": "flwsec_test_1234567890",
      "payload": "{\"event\":\"charge.completed\",\"data\":{\"id\":67890,\"tx_ref\":\"pi_test_002\"}}",
      "header_name": "verif-hash",
      "expected_signature": "a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b",
      "should_pass": true
    },
    {
      "name": "flutterwave_invalid_signature",
      "provider": "flutterwave",
      "secret": "flwsec_test_1234567890",
      "payload": "{\"event\":\"charge.completed\",\"data\":{\"id\":67890,\"tx_ref\":\"pi_test_002\"}}",
      "header_name": "verif-hash",
      "expected_signature": "wrong_signature",
      "should_pass": false,
      "expected_error": "Invalid Flutterwave signature"
    },
    {
      "name": "manual_admin_valid_signature",
      "provider": "manual_admin",
      "secret": "admin_secret_key_12345",
      "payload": "{\"action\":\"manual_deposit\",\"amount\":100000}",
      "header_name": "x-admin-signature",
      "expected_signature": "admin_secret_key_12345",
      "should_pass": true
    },
    {
      "name": "manual_admin_invalid_signature",
      "provider": "manual_admin",
      "secret": "admin_secret_key_12345",
      "payload": "{\"action\":\"manual_deposit\",\"amount\":100000}",
      "header_name": "x-admin-signature",
      "expected_signature": "wrong_admin_secret",
      "should_pass": false,
      "expected_error": "Invalid admin signature"
    },
    {
      "name": "legacy_valid_signature",
      "provider": "psp",
      "secret": "webhook_secret_legacy",
      "payload": "{\"status\":\"confirmed\",\"externalRef\":\"pi_test_003\"}",
      "header_name": "x-webhook-signature",
      "expected_signature": "webhook_secret_legacy",
      "should_pass": true
    },
    {
      "name": "legacy_invalid_signature",
      "provider": "psp",
      "secret": "webhook_secret_legacy",
      "payload": "{\"status\":\"confirmed\",\"externalRef\":\"pi_test_003\"}",
      "header_name": "x-webhook-signature",
      "expected_signature": "wrong_secret",
      "should_pass": false,
      "expected_error": "Invalid webhook signature"
    },
    {
      "name": "bank_transfer_not_supported",
      "provider": "bank_transfer",
      "secret": "",
      "payload": "{}",
      "header_name": "",
      "expected_signature": "",
      "should_pass": false,
      "expected_error": "Bank transfers do not support webhook signature validation"
    }
  ],

  "staking_metadata_hash_vectors": [
