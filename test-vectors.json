    },
    {
      "name": "unstake_with_metadata",
      "input": {
        "tx_type": "unstake",
        "amount_usdc": "500000",
        "timestamp": 1620000000,
        "deal_id": "DEAL001",
        "listing_id": "LIST001",
        "metadata": {
          "reference": "TX123456789",
          "source": "bank_transfer"
        }
      },
      "expected_canonical_payload_v1": "v1|tx_type=unstake|amount_usdc=500000|token=<TOKEN>|user=<USER>|timestamp=1620000000|deal_id=DEAL001|listing_id=LIST001|meta=reference=TX123456789&source=bank_transfer",
      "expected_sha256": "348091ff408ec28120067b9708aee87b147834307a57c23b36821ffced58e5a0"
    }
  ]
}
